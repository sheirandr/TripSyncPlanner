  <!-- FUNCTIONAL JAVASCRIPT LAYER -->
  <script>
    // Initialize Lucide Icons
    lucide.createIcons();

    // 1. Mobile Menu Toggle Logic
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // 2. Audio Book Simulation Engine (Play / Pause Button Toggle)
    const audioButtons = document.querySelectorAll('.audio-btn');
    audioButtons.forEach(btn => {
      btn.addEventListener('click', function() {
        const icon = this.querySelector('.btn-icon');
        const isPlaying = icon.getAttribute('data-lucide') === 'square';
        
        // Reset all buttons first to simulate single-stream playback
        audioButtons.forEach(b => {
          const bIcon = b.querySelector('.btn-icon');
          bIcon.setAttribute('data-lucide', 'play');
          b.classList.remove('bg-red-600', 'hover:bg-red-700');
          b.classList.add('bg-emerald-600', 'hover:bg-emerald-700');
        });

        if (!isPlaying) {
          // Toggle to stop state
          icon.setAttribute('data-lucide', 'square');
          this.classList.remove('bg-emerald-600', 'hover:bg-emerald-700');
          this.classList.add('bg-red-600', 'hover:bg-red-700');
          alert('Memutar rekaman audio materi narasi digital...');
        } else {
          alert('Audio dihentikan.');
        }
        lucide.createIcons(); // Refresh icons inside modified buttons
      });
    });

    // 3. Dynamic Booking Form Submission Mockup
    const form = document.getElementById('booking-form');
    const loadingState = document.getElementById('form-loading');
    const successState = document.getElementById('form-success');
    const visitorCountDisplay = document.getElementById('visitor-count');
    const trafficLight = document.getElementById('traffic-light');
    const capacityStatus = document.getElementById('capacity-status');

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const numVisitorsInput = parseInt(document.getElementById('num-visitors').value);
      const currentCount = parseInt(visitorCountDisplay.innerText);
      const targetCount = currentCount + numVisitorsInput;

      // Rule Validation Check: Carrying Capacity Boundary Limit 500
      if (targetCount > 500) {
        alert('Maaf, kuota kunjungan untuk tanggal yang dipilih sudah melampaui batas carrying capacity harian (Maksimal 500 orang). Silakan kurangi jumlah personil kelompok atau pilih tanggal lain.');
        return;
      }

      form.classList.add('hidden');
      loadingState.classList.remove('hidden');

      // Simulate API Network Delay Processing
      setTimeout(() => {
        loadingState.classList.add('hidden');
        successState.classList.remove('hidden');
        
        // Dynamically update the Carrying Capacity Visitor Monitor dashboard in real-time
        visitorCountDisplay.innerText = targetCount;

        // Dynamic State adjustments if approaches dangerous carrying bounds
        if (targetCount >= 400 && targetCount <= 500) {
          trafficLight.className = "w-4 h-4 rounded-full bg-yellow-500 capacity-pulse";
          capacityStatus.innerText = "Status Waspada: Kuota padat, mendekati batas maksimal daya tampung.";
          capacityStatus.className = "text-yellow-500 text-sm mt-2 font-medium";
        } else if (targetCount >= 500) {
          trafficLight.className = "w-4 h-4 rounded-full bg-red-500";
          capacityStatus.innerText = "Status Kritis: Batas daya tampung terpenuhi. Gerbang ditutup.";
          capacityStatus.className = "text-red-500 text-sm mt-2 font-medium";
        }
      }, 1500);
    });
  </script>
